{
  "$schema": "https://railway.app/standard-schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn -b 0.0.0.0:$PORT --workers 1 --threads 8 --timeout 120 --preload app:app",
    "restartPolicyType": "ON_FAILURE",
    "healthCheckPath": "/",
    "healthCheckTimeout": 120
  }
}
